# Sao chép thành .env rồi điền giá trị THẬT (đừng commit .env):  cp .env.example .env

# --- PostgreSQL ---
POSTGRES_USER=miki
POSTGRES_DB=miki
POSTGRES_PASSWORD=doi_mat_khau_db_manh_o_day

# --- Bảo mật ---
# Chuỗi ngẫu nhiên dài ký JWT — tạo bằng: openssl rand -hex 32
JWT_SECRET=doi_thanh_chuoi_ngau_nhien_that_dai

# --- Tài khoản admin khởi tạo lần đầu (đăng nhập admin.html) ---
ADMIN_EMAIL=admin@mikimakeup.vn
ADMIN_PASSWORD=doi_mat_khau_admin_o_day

# --- Cổng API (chỉ mở trên localhost VPS, cho tunnel/reverse-proxy) ---
API_PORT=3000

# --- Cloudflare Tunnel (khuyến nghị: HTTPS cho API, không cần mở port) ---
# 1) Cloudflare Zero Trust → Networks → Tunnels → Create tunnel (Docker)
# 2) Copy token, dán vào TUNNEL_TOKEN
# 3) Trong tunnel, thêm Public hostname: api.mikimakeup.shop  →  Service: http://api:3000
# 4) Bỏ dấu # ở dòng COMPOSE_PROFILES bên dưới để bật cloudflared
# COMPOSE_PROFILES=tunnel
TUNNEL_TOKEN=
